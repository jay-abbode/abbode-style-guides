# --- NextAuth ---
AUTH_SECRET=            # generate with: openssl rand -base64 32
AUTH_TRUST_HOST=true

# --- Google OAuth (who can sign in) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ALLOWED_DOMAIN=shopabbode.com

# --- Google service account (reads the Sheet + Assets) ---
# Local dev: instead of these two, drop the service-account JSON in the project
# root as google-credentials.json (gitignored).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# --- Backend location (defaults point at STYLE GUIDE BACKEND) ---
STYLE_GUIDE_SHEET_ID=1GxnciAjeX2evwaXiHa8btevwyuLq_L-wl9W3wOEAvOA
